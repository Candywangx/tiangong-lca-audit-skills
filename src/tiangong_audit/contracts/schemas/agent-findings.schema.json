{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://tiangong-audit.local/schemas/agent-findings.schema.json",
  "title": "Tiangong Audit Agent Findings",
  "type": "object",
  "required": ["schema_version", "review_id", "reviewed_by", "rule_reviews"],
  "properties": {
    "schema_version": {"const": "tiangong-audit-agent-findings-v2"},
    "review_id": {"type": "string"},
    "dataset_id": {"type": "string"},
    "dataset_type": {"enum": ["process", "model", ""]},
    "reviewed_by": {"type": "string", "minLength": 1},
    "reviewed_at": {"type": "string"},
    "source_documents_read": {"type": "array", "items": {"type": "string"}},
    "rule_reviews": {
      "type": "array",
      "items": {"$ref": "#/$defs/rule_review"}
    },
    "additional_findings": {
      "type": "array",
      "items": {"$ref": "#/$defs/additional_finding"}
    },
    "platform_overrides": {
      "type": "array",
      "items": {"$ref": "#/$defs/platform_override"}
    },
    "precheck_resolutions": {
      "type": "array",
      "items": {"$ref": "#/$defs/precheck_resolution"}
    }
  },
  "additionalProperties": false,
  "$defs": {
    "rule_review": {
      "type": "object",
      "required": ["rule_id", "verdict"],
      "properties": {
        "rule_id": {"type": "string", "minLength": 1},
        "verdict": {"enum": ["pass", "fail", "cannot_judge", "not_applicable"]},
        "location": {"type": "string"},
        "evidence": {"type": "string"},
        "judgment": {"type": "string"},
        "suggestion": {"type": "string"},
        "severity": {"enum": ["blocking", "advisory", "manual_review", "input_gap", ""]},
        "evidence_refs": {"type": "array", "items": {"type": "string"}},
        "platform": {"$ref": "#/$defs/platform_projection"}
      },
      "additionalProperties": false,
      "allOf": [
        {
          "if": {"properties": {"verdict": {"const": "fail"}}},
          "then": {
            "required": ["evidence", "severity", "suggestion", "evidence_refs"],
            "properties": {
              "severity": {"enum": ["blocking", "advisory", "manual_review", "input_gap"]},
              "evidence_refs": {"minItems": 1}
            }
          }
        },
        {
          "if": {"properties": {"verdict": {"const": "pass"}}},
          "then": {
            "required": ["evidence", "evidence_refs"],
            "properties": {"evidence_refs": {"minItems": 1}}
          }
        },
        {
          "if": {"properties": {"verdict": {"enum": ["cannot_judge", "not_applicable"]}}},
          "then": {"required": ["judgment"]}
        },
        {
          "if": {"properties": {"verdict": {"enum": ["pass", "not_applicable"]}}},
          "then": {
            "properties": {
              "severity": {"const": ""},
              "platform": {
                "properties": {"disposition": {"const": "internal_only"}}
              }
            }
          }
        },
        {
          "if": {"properties": {"verdict": {"const": "cannot_judge"}}},
          "then": {
            "properties": {
              "severity": {"enum": ["manual_review", ""]},
              "platform": {
                "properties": {
                  "disposition": {"enum": ["clarification", "internal_only"]}
                }
              }
            }
          }
        },
        {
          "if": {
            "required": ["severity"],
            "properties": {"severity": {"const": "blocking"}}
          },
          "then": {
            "properties": {
              "platform": {"properties": {"disposition": {"const": "required"}}}
            }
          }
        },
        {
          "if": {
            "required": ["severity"],
            "properties": {"severity": {"const": "advisory"}}
          },
          "then": {
            "properties": {
              "platform": {
                "properties": {
                  "disposition": {"enum": ["suggested", "internal_only"]}
                }
              }
            }
          }
        },
        {
          "if": {
            "required": ["severity"],
            "properties": {"severity": {"enum": ["manual_review", "input_gap"]}}
          },
          "then": {
            "properties": {
              "platform": {
                "properties": {
                  "disposition": {"enum": ["clarification", "internal_only"]}
                }
              }
            }
          }
        }
      ]
    },
    "additional_finding": {
      "type": "object",
      "required": ["rule_id", "severity", "location", "evidence", "judgment", "suggestion"],
      "properties": {
        "rule_id": {"type": "string"},
        "severity": {"enum": ["blocking", "advisory", "manual_review", "input_gap"]},
        "location": {"type": "string", "minLength": 1},
        "evidence": {"type": "string", "minLength": 1},
        "judgment": {"type": "string", "minLength": 1},
        "suggestion": {"type": "string", "minLength": 1},
        "source": {"type": "string"},
        "evidence_refs": {"type": "array", "items": {"type": "string"}},
        "platform": {"$ref": "#/$defs/platform_projection"}
      },
      "additionalProperties": false,
      "allOf": [
        {
          "if": {"properties": {"severity": {"const": "blocking"}}},
          "then": {
            "properties": {
              "platform": {"properties": {"disposition": {"const": "required"}}}
            }
          }
        },
        {
          "if": {"properties": {"severity": {"const": "advisory"}}},
          "then": {
            "properties": {
              "platform": {
                "properties": {
                  "disposition": {"enum": ["suggested", "internal_only"]}
                }
              }
            }
          }
        },
        {
          "if": {"properties": {"severity": {"enum": ["manual_review", "input_gap"]}}},
          "then": {
            "properties": {
              "platform": {
                "properties": {
                  "disposition": {"enum": ["clarification", "internal_only"]}
                }
              }
            }
          }
        }
      ]
    },
    "platform_projection": {
      "type": "object",
      "required": ["disposition"],
      "properties": {
        "disposition": {
          "enum": ["required", "clarification", "suggested", "internal_only"]
        },
        "message": {"type": "string", "minLength": 1, "pattern": "\\S"}
      },
      "additionalProperties": false,
      "allOf": [
        {
          "if": {"properties": {"disposition": {"const": "internal_only"}}},
          "then": {"not": {"required": ["message"]}},
          "else": {"required": ["message"]}
        }
      ]
    },
    "platform_override": {
      "type": "object",
      "required": ["rule_id", "location", "platform"],
      "properties": {
        "rule_id": {"type": "string", "minLength": 1, "pattern": "\\S"},
        "location": {"type": "string", "minLength": 1, "pattern": "\\S"},
        "platform": {"$ref": "#/$defs/platform_projection"}
      },
      "additionalProperties": false
    },
    "precheck_resolution": {
      "type": "object",
      "required": ["rule_id", "location", "resolution", "reason", "evidence_refs"],
      "properties": {
        "rule_id": {"type": "string", "minLength": 1, "pattern": "^\\S(?:.*\\S)?$"},
        "location": {"type": "string", "minLength": 1, "pattern": "^\\S(?:.*\\S)?$"},
        "resolution": {"const": "refuted"},
        "reason": {"type": "string", "minLength": 1, "pattern": "\\S"},
        "evidence_refs": {
          "type": "array",
          "minItems": 1,
          "items": {"type": "string", "minLength": 1, "pattern": "\\S"}
        }
      },
      "additionalProperties": false
    }
  }
}
